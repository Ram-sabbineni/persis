# Copy to .env and adjust for your environment.
# Local API (see backend launchSettings.json for ports):
VITE_API_BASE_URL=https://localhost:7288

# Routing: omit or true = HashRouter (/#/checkout) — works everywhere.
# false = BrowserRouter — needs SPA fallback on your static host.
# VITE_USE_HASH_ROUTER=false

# Azure App Service example:
# VITE_API_BASE_URL=https://your-persis-api.azurewebsites.net
