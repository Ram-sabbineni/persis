# --- Production build only ---
# Set before `npm run build` (Azure App Service URL, no trailing slash):
# VITE_API_BASE_URL=https://your-persis-api.azurewebsites.net

# --- Local dev (npm run dev) ---
# Requests use Vite proxy: /api → API. Target defaults to http://localhost:5288.
# Override if your API uses another URL:
# VITE_API_BASE_URL=http://localhost:5288
# VITE_API_PROXY_TARGET=http://localhost:5288

# Routing: HashRouter unless false
# VITE_USE_HASH_ROUTER=false
